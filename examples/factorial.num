# factorial.num — iterative factorial
#
# vars[0] = n (input)
# vars[1] = accumulator (starts at 1)

5 0 &       # n = 5
1 1 &       # acc = 1

# Loop while n > 0
|0 0 11
30
    |1 |0 * 1 &     # acc = acc * n
    |0 1 - 0 &      # n   = n - 1
    |0 0 11         # next condition: n > 0
;

"5! = "
|1 |
